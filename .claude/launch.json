{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI (backend)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "app.workers.celery_app", "worker", "--loglevel=info"],
      "port": 0
    },
    {
      "name": "Celery Beat (scheduler)",
      "runtimeExecutable": "celery",
      "runtimeArgs": ["-A", "app.workers.celery_app", "beat", "--loglevel=info"],
      "port": 0
    },
    {
      "name": "Redis",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["run", "--rm", "-p", "6379:6379", "redis:7-alpine"],
      "port": 6379
    }
  ]
}
