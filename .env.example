# ─── App ───────────────────────────────────────────────
APP_NAME=fincontrol
APP_ENV=development
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── Database (Supabase connection string) ──────────────
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db>
DATABASE_URL_SYNC=postgresql://<user>:<password>@<host>:5432/<db>

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Open Finance (Pluggy) ──────────────────────────────
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Email ──────────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@fincontrol.app

# ─── Admin ──────────────────────────────────────────────
ADMIN_EMAILS=

# ─── Stripe Webhook ─────────────────────────────────────
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

PLUGGY_WEBHOOK_URL=https://yourdomain.com/api/v1/webhooks/pluggy
PLUGGY_WEBHOOK_SECRET=

# ─── CORS ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://fincontrol.app
